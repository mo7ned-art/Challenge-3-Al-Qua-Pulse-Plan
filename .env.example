# Al Qua'a Pulse — environment variables
#
# All variables are OPTIONAL. The app runs end-to-end without any of these.
# Configure them to enable live persistence (Supabase) and AI briefs.

# --- Supabase (optional) ---
# Without these, the app uses an in-memory store with 40 pre-seeded demo responses.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...
# SUPABASE_SERVICE_ROLE_KEY=...

# --- Admin PIN (optional) ---
# If unset, the admin opens in demo mode (any PIN or empty unlocks it).
# Set this in production.
# ADMIN_PIN=change-me-1234

# --- Demo mode flag (optional) ---
# Set to "true" to force demo mode (e.g. on a public preview deployment).
# NEXT_PUBLIC_DEMO_MODE=true

# --- AI brief (optional) ---
# If unset, the founder-brief endpoint returns a deterministic template.
# OpenAI-compatible. The base URL defaults to https://api.openai.com
# AI_API_KEY=sk-...
# AI_BASE_URL=https://api.openai.com
# AI_MODEL=gpt-4o-mini
